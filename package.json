{
  "name": "routster",
  "version": "1.2.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:frontend": "cd frontend && npm install && npm run build",
    "postinstall": "cd frontend && npm install",
    "build:exe": "npm run build:frontend && electron-builder --win"
  },
  "keywords": [
    "knowledge-management",
    "automation",
    "classifier",
    "electron",
    "local-first",
    "bookmarks",
    "data-pipeline"
  ],
  "author": "outdatedcaveman",
  "license": "MIT",
  "description": "Routster — A universal, local-first automation engine that classifies, routes, and exports files and bookmarks to any service. Features adaptive NLP, 12+ connectors, custom APIs, and a modular plugin system.",
  "repository": {
    "type": "git",
    "url": "https://github.com/outdatedcaveman/routster"
  },
  "build": {
    "appId": "com.routster.app",
    "productName": "Routster",
    "directories": {
      "output": "dist-app"
    },
    "win": {
      "target": [
        "portable",
        "dir"
      ],
      "icon": "assets/icon.png"
    },
    "forceCodeSigning": false,
    "files": [
      "server.js",
      "classifier.js",
      "fetcher.js",
      "main.js",
      "db.js",
      "nlp.js",
      "history_sweep.js",
      "bookmark_trainer.js",
      "link_analyzer.js",
      "export-engine.js",
      "trigger-engine.js",
      "connectors/**/*",
      "triggers/**/*",
      "frontend/dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets/",
        "to": "assets/",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "axios": "^1.7.9",
    "better-sqlite3": "^12.8.0",
    "body-parser": "^1.20.3",
    "cheerio": "^1.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsdom": "^29.0.1",
    "multer": "^1.4.5-lts.1",
    "p-limit": "^7.3.0",
    "png-to-ico": "^3.0.1",
    "turndown": "^7.2.2"
  },
  "devDependencies": {
    "electron": "^34.2.0",
    "electron-builder": "^26.4.1"
  }
}
