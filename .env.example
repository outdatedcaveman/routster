# === KMS Auto-Router Environment Configuration ===
# Copy this file to .env and fill in YOUR credentials.
# Never commit your .env file to Git!

# Zotero (Required for Article/Book export)
# Get your API key at: https://www.zotero.org/settings/keys
# Your User ID is visible at: https://www.zotero.org/settings/keys
ZOTERO_API_KEY=
ZOTERO_USER_ID=

# Notion (Optional - for Reference Portal export)
# Create an integration at: https://www.notion.so/my-integrations
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Instapaper (Optional - for Read Later export)
# Uses your Instapaper login credentials
INSTAPAPER_USERNAME=
INSTAPAPER_PASSWORD=

# Obsidian (Optional - local vault path for markdown export)
# Point to your vault's Inbox folder
OBSIDIAN_VAULT_PATH=

# Paperpile (Optional - Google Drive sync folder)
PAPERPILE_SYNC_PATH=
