{
  "manifest_version": 3,
  "name": "Routster",
  "version": "1.0",
  "description": "Intelligent bookmark classification and routing — send tabs to your local Routster engine.",
  "permissions": [
    "activeTab",
    "tabs",
    "bookmarks",
    "alarms"
  ],
  "host_permissions": [
    "http://localhost:4000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Send to KMS"
  }
}
